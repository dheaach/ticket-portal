[debug] [2026-04-01T09:04:45.257Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/dtlabs-aa92c/rulesets {"name":"projects/dtlabs-aa92c/rulesets/753047ab-d10b-45f4-b40a-4f892904c475","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // NextAuth session + Firebase custom token (uid = app user id). Server creates docs via Admin SDK.\n    match /users/{userId}/ticketNotifications/{docId} {\n      allow read: if request.auth != null && request.auth.uid == userId;\n      allow create: if false;\n      allow delete: if request.auth != null && request.auth.uid == userId;\n      allow update: if request.auth != null && request.auth.uid == userId;\n    }\n\n    // Siapa sedang membuka detail tiket (heartbeat dari client; uid = NextAuth user id)\n    match /ticket_presence/{ticketId}/viewers/{viewerId} {\n      allow read: if request.auth != null;\n      allow create, update: if request.auth != null && request.auth.uid == viewerId;\n      allow delete: if request.auth != null && request.auth.uid == viewerId;\n    }\n\n    // Counter versi saja (bukan isi tiket). Refetch tetap lewat GET /api/tickets/:id/detail (NextAuth cookie).\n    // Tanpa read publik di sini, listener gagal kalau client belum sign-in Firebase (custom token).\n    match /ticket_data_sync/{ticketId} {\n      allow read: if true;\n      allow write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-01T09:04:44.452735Z","metadata":{"services":["cloud.firestore"]}}
