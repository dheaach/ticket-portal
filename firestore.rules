rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // NextAuth session + Firebase custom token (uid = app user id). Server creates docs via Admin SDK.
    match /users/{userId}/ticketNotifications/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Siapa sedang membuka detail tiket (heartbeat dari client; uid = NextAuth user id)
    match /ticket_presence/{ticketId}/viewers/{viewerId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == viewerId;
      allow delete: if request.auth != null && request.auth.uid == viewerId;
    }
  }
}
